{
    "name": "badgerwise/wc-connect",
    "description": "Framework-agnostic WooCommerce REST API client with WordPress Application Password authentication.",
    "type": "library",
    "license": "MIT",
    "keywords": ["woocommerce", "wordpress", "rest-api", "api-client", "application-passwords", "psr-18"],
    "require": {
        "php": ">=8.3",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "php-http/discovery": "^1.19"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "guzzlehttp/guzzle": "^7.8",
        "phpstan/phpstan": "^2.0"
    },
    "suggest": {
        "guzzlehttp/guzzle": "PSR-18 HTTP client (recommended; Laravel projects already include it)",
        "symfony/http-client": "Alternative PSR-18 HTTP client"
    },
    "autoload": {
        "psr-4": { "BadgerWise\\WcConnect\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "BadgerWise\\WcConnect\\Tests\\": "tests/" }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": { "php-http/discovery": true }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src --level=8"
    },
    "minimum-stability": "stable"
}
